<?xml version="1.0" encoding="UTF-8"?>
<!-- audio_effects.xml — Samsung Galaxy A01q (SM-A015M)    -->
<!-- Android 13 usa .xml (el .conf fue deprecado en API 30) -->
<audio_effects_conf version="2.0" xmlns="http://schemas.android.com/audio/audio_effects_conf/v2_0">

    <libraries>
        <library name="bundle"      path="libbundlewrapper.so"/>
        <library name="reverb"      path="libreverbwrapper.so"/>
        <library name="qcompostprocbundle" path="libqcompostprocbundle.so"/>
        <library name="qcomvisualizer"     path="libqcomvisualizer.so"/>
        <library name="qcomvoiceprocessing" path="libqcomvoiceprocessing.so"/>
        <library name="volumelistener"     path="libvolumelistener.so"/>
    </libraries>

    <effects>
        <!-- Ecualizador -->
        <effectProxy name="equalizer" library="qcompostprocbundle" uuid="c8e70ecd-48ca-456e-8a4f-0002a5d5c51b">
            <libsw library="bundle" uuid="ce772f20-847d-11df-bb17-0002a5d5c51b"/>
            <libhw library="qcompostprocbundle" uuid="c8e70ecd-48ca-456e-8a4f-0002a5d5c51b"/>
        </effectProxy>

        <!-- Bass Boost -->
        <effectProxy name="bassboost" library="qcompostprocbundle" uuid="fa8181f2-588b-11e2-9e96-0800200c9a66">
            <libsw library="bundle" uuid="8631f300-72e2-11df-b57e-0002a5d5c51b"/>
            <libhw library="qcompostprocbundle" uuid="fa8181f2-588b-11e2-9e96-0800200c9a66"/>
        </effectProxy>

        <!-- Virtualizer -->
        <effectProxy name="virtualizer" library="qcompostprocbundle" uuid="1d4033c0-8557-11e2-9e96-0800200c9a66">
            <libsw library="bundle" uuid="1d4033c0-8557-11e2-9e96-0800200c9a66"/>
            <libhw library="qcompostprocbundle" uuid="1d4033c0-8557-11e2-9e96-0800200c9a66"/>
        </effectProxy>

        <!-- Reverb -->
        <effect name="presetreverb"  library="reverb" uuid="172cdf00-a3bc-11df-a72f-0002a5d5c51b"/>
        <effect name="envchangereverb" library="reverb" uuid="4a387fc0-8ab3-11df-8bad-0002a5d5c51b"/>

        <!-- Compresor de voz — ANC headset support -->
        <effect name="agc2" library="qcomvoiceprocessing" uuid="ae3c653b-be18-4ab8-8938-418f0a7f06ac"/>

        <!-- Anulación de ruido -->
        <effect name="ns" library="qcomvoiceprocessing" uuid="c06c8400-8e06-11e0-9cb6-0002a5d5c51b"/>

        <!-- Acoustic Echo Canceler -->
        <effect name="aec" library="qcomvoiceprocessing" uuid="0f8d0d2a-59e5-45fe-b6e4-248c8a799109"/>

        <!-- Volume listener — spkr_prot.enable=true confirmado -->
        <effect name="volumelistener" library="volumelistener" uuid="8b1f0fc0-6d68-11e2-aa09-0002a5d5c51b"/>

        <!-- Visualizer -->
        <effect name="visualizer" library="qcomvisualizer" uuid="d069d9e0-8329-11df-9168-0002a5d5c51b"/>

    </effects>

    <postprocess>
        <stream type="music">
            <apply effect="equalizer"/>
            <apply effect="bassboost"/>
            <apply effect="virtualizer"/>
            <apply effect="volumelistener"/>
        </stream>
        <stream type="ring">
            <apply effect="volumelistener"/>
        </stream>
    </postprocess>

    <preprocess>
        <stream type="voice_communication">
            <apply effect="aec"/>
            <apply effect="ns"/>
        </stream>
    </preprocess>

</audio_effects_conf>
