# init.qcom.power.rc — Samsung Galaxy A01q (SM-A015M)
# Configuración de energía para SDM439 / msm8937
# 8× Cortex-A53 @ 1.95GHz

on enable-low-power
    # ============================================================
    # CPU Frequency limits — SDM439
    # Cluster 0: cpu0-3, Cluster 1: cpu4-7
    # ============================================================
    write /sys/devices/system/cpu/cpu0/cpufreq/scaling_min_freq 200000
    write /sys/devices/system/cpu/cpu0/cpufreq/scaling_max_freq 1958400
    write /sys/devices/system/cpu/cpu4/cpufreq/scaling_min_freq 200000
    write /sys/devices/system/cpu/cpu4/cpufreq/scaling_max_freq 1958400

    # Governor: schedutil para mejor balance en Android 13
    write /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor schedutil
    write /sys/devices/system/cpu/cpu4/cpufreq/scaling_governor schedutil

    # Rate limits para schedutil
    write /sys/devices/system/cpu/cpufreq/policy0/schedutil/up_rate_limit_us 500
    write /sys/devices/system/cpu/cpufreq/policy0/schedutil/down_rate_limit_us 20000
    write /sys/devices/system/cpu/cpufreq/policy4/schedutil/up_rate_limit_us 500
    write /sys/devices/system/cpu/cpufreq/policy4/schedutil/down_rate_limit_us 20000

    # ============================================================
    # GPU — Adreno 505
    # ============================================================
    write /sys/class/kgsl/kgsl-3d0/devfreq/governor msm-adreno-tz
    write /sys/class/kgsl/kgsl-3d0/default_pwrlevel 5

    # ============================================================
    # Input Boost
    # ============================================================
    write /sys/module/cpu_boost/parameters/input_boost_enabled 1
    write /sys/module/cpu_boost/parameters/input_boost_ms 40

    # ============================================================
    # ZRAM — activar swap comprimido
    # ============================================================
    write /sys/block/zram0/max_comp_streams 8
    swapon_all /vendor/etc/fstab.qcom

    # ============================================================
    # LPM (Low Power Mode) — SDM439
    # ============================================================
    write /sys/module/lpm_levels/system/perf-cluster/cpu0/c1/idle_enabled Y
    write /sys/module/lpm_levels/system/perf-cluster/cpu0/c2/idle_enabled Y
    write /sys/module/lpm_levels/system/perf-cluster/cpu0/c3/idle_enabled Y

    # ============================================================
    # Scheduler
    # ============================================================
    write /proc/sys/kernel/sched_boost 0
    write /proc/sys/kernel/sched_migration_cost_ns 5000000

on charger
    write /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor powersave
    write /sys/devices/system/cpu/cpu1/online 0
    write /sys/devices/system/cpu/cpu2/online 0
    write /sys/devices/system/cpu/cpu3/online 0
    write /sys/devices/system/cpu/cpu4/online 0
    write /sys/devices/system/cpu/cpu5/online 0
    write /sys/devices/system/cpu/cpu6/online 0
    write /sys/devices/system/cpu/cpu7/online 0

on property:sys.boot_completed=1
    trigger enable-low-power

    # Post-boot: liberar memoria
    write /proc/sys/vm/drop_caches 3
