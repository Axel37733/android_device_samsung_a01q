<?xml version="1.0" encoding="utf-8"?>
<!-- overlay/frameworks/base/core/res/res/values/config.xml -->
<!-- Samsung Galaxy A01q (SM-A015M) — 2GB RAM device       -->
<resources>

    <!-- ============================================================ -->
    <!-- DISPLAY — 320dpi, confirmado ro.sf.lcd_density=320           -->
    <!-- ============================================================ -->
    <bool name="config_enableTranslucentDecor">false</bool>
    <bool name="config_windowEnableSplitWindowAnimation">false</bool>

    <!-- ============================================================ -->
    <!-- MEMORIA — 2GB RAM, heapgrowthlimit=128m del getprop          -->
    <!-- ============================================================ -->
    <!-- Reducir animaciones para mejor rendimiento en 2GB -->
    <bool name="config_avoidGfxAccel">false</bool>

    <!-- ============================================================ -->
    <!-- WIFI — qcwcn, single band (SDM439)                           -->
    <!-- ============================================================ -->
    <bool name="config_wifi_framework_enable_associated_network_selection">true</bool>
    <integer name="config_wifi_framework_scan_interval">15000</integer>
    <bool name="config_wifi_softap_acs_supported">false</bool>
    <bool name="config_wifi_p2p_mac_randomization_supported">false</bool>

    <!-- ============================================================ -->
    <!-- BLUETOOTH — Pronto SoC                                       -->
    <!-- ============================================================ -->
    <bool name="config_bluetooth_le_peripheral_mode_supported">true</bool>

    <!-- ============================================================ -->
    <!-- TELEFONIA — Single SIM                                       -->
    <!-- ============================================================ -->
    <integer name="config_num_phone_accounts">1</integer>

    <!-- ============================================================ -->
    <!-- GPS — gnss_service confirmado activo                         -->
    <!-- ============================================================ -->
    <bool name="config_gpsAltitudeMslReporting">false</bool>

    <!-- ============================================================ -->
    <!-- USB — sys.usb.configfs=1                                     -->
    <!-- ============================================================ -->
    <bool name="config_usbChargingMessage">true</bool>

    <!-- ============================================================ -->
    <!-- No NFC, no fingerprint, no face unlock (presupuesto)         -->
    <!-- ============================================================ -->
    <bool name="config_nfcAvailable">false</bool>
    <bool name="config_fingerprintSupportsGestures">false</bool>

    <!-- Screen timeout -->
    <integer name="config_screenBrightnessDim">10</integer>
    <integer name="config_screenBrightnessSettingMinimum">1</integer>
    <integer name="config_screenBrightnessSettingMaximum">255</integer>
    <integer name="config_screenBrightnessSettingDefault">128</integer>

</resources>
